# ─── API mode ────────────────────────────────────────────────────────────────
# mock = read seed data from /data/mock (no DB)
# live = read from /api/public/v1 (this app's own DB)
PROJECTX_API_MODE=live

# Leave NEXT_PUBLIC_PROJECTX_API_BASE empty in normal deploys — the live client
# falls back to same-origin "/api" so the public site talks to its own backend.
NEXT_PUBLIC_PROJECTX_API_BASE=
NEXT_PUBLIC_PROJECTX_API_KEY=
NEXT_PUBLIC_PROJECTX_ORIGIN=

# ─── Public site mode ────────────────────────────────────────────────────────
# live | coming-soon  (coming-soon shows the under-construction page at /)
NEXT_PUBLIC_SITE_MODE=live

# ─── Database (Postgres in the deploy compose) ───────────────────────────────
DATABASE_URL=postgresql://shaman:shaman@db:5432/shaman

# ─── Admin auth ──────────────────────────────────────────────────────────────
# 32+ char secret for iron-session cookie encryption. Rotate annually.
SESSION_PASSWORD=replace-me-with-a-32-character-or-longer-random-string

# Bootstrap admin — only used on the very first deploy when AdminUser is
# empty. After an admin exists, both vars can stay blank (they're ignored).
# When SET on first deploy: 12+ chars required, and the literal "changeme"
# is rejected. The seed will skip silently if either is empty.
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=

# ─── AWS S3 (media uploads — bucket: ims-shaman-photos, ap-south-1) ──────────
# In prod (EC2) the instance role grants S3 access — leave the key vars unset.
# Locally, set both to use a personal IAM user.
S3_REGION=ap-south-1
S3_BUCKET=ims-shaman-photos
S3_PUBLIC_BASE=https://ims-shaman-photos.s3.ap-south-1.amazonaws.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Run prisma db seed on container start. Idempotent — safe to leave at 1.
RUN_DB_SEED=1

# ─── Deploy: Watchtower (pull-based, no CI/SSH) ──────────────────────────────
# How often Watchtower polls Docker Hub for a new :prod image (seconds).
WATCHTOWER_POLL_INTERVAL=60
# Optional shoutrrr URL for deploy notifications (slack://…, ntfy://…, etc.)
WATCHTOWER_NOTIFICATION_URL=

# Image pin. Watchtower watches this image tag and recreates `shaman-web`
# whenever Docker Hub serves a new digest. Don't include the SHA suffix
# — you want the rolling :prod tag here.
DOCKER_IMAGE=rpandox/shamanktmweb:prod
