# API mode: mock (default, ships with demo data) or live (hits Public Data API).
PROJECTX_API_MODE=mock

# Set the three below when an API key is issued.
# The Origin pin (Public Data API auth model) protects the key in the bundle —
# requests from any other origin are rejected.
NEXT_PUBLIC_PROJECTX_API_BASE=https://api.projectx.example/api/v1
NEXT_PUBLIC_PROJECTX_API_KEY=
NEXT_PUBLIC_PROJECTX_ORIGIN=https://shamankathmandu.com

# Public site mode: live | coming-soon. coming-soon shows the under-construction page at /.
NEXT_PUBLIC_SITE_MODE=live
